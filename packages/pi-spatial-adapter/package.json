{
  "name": "@dimos/pi-spatial-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/tool-definitions.v1.json dist/tool-definitions.v1.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run build && tsc -p tsconfig.test.json && cp src/tool-definitions.v1.json dist-test/src/tool-definitions.v1.json && node --test dist-test/test/*.test.js"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
