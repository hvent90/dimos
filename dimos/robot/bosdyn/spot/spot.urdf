  <joint name="cover to body_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0429 0 0.0597"/>
    <parent link="body"/>
    <child link="cover"/>
  </joint>
  <!-- Static fisheye camera mounts. Boston Dynamics does not ship camera frames
       in spot_description, so these are the CoSTAR/subt estimates (osrf/subt
       bosdyn_spot), which were fit against a real Spot. Each position has a
       gazebo camera_link (X-forward, Y-left, Z-up) and a ROS optical child
       (Z-forward, X-right, Y-down; the canonical rpy="-pi/2 0 -pi/2"). The same
       physical mount feeds both the grayscale and depth stream at that position. -->
  <link name="frontleft_camera"/>
  <joint name="frontleft_camera_joint" type="fixed">
    <origin rpy="1.355558 0.353917 -0.554196" xyz="0.415 0.037 -0.01"/>
    <parent link="body"/>
    <child link="frontleft_camera"/>
  </joint>
  <link name="frontleft_camera_optical"/>
  <joint name="frontleft_camera_optical_joint" type="fixed">
    <origin rpy="-1.5707963 0 -1.5707963" xyz="0 0 0"/>
    <parent link="frontleft_camera"/>
    <child link="frontleft_camera_optical"/>
  </joint>
  <link name="frontright_camera"/>
  <joint name="frontright_camera_joint" type="fixed">
    <origin rpy="-1.355558 0.353917 0.554196" xyz="0.415 -0.037 -0.01"/>
    <parent link="body"/>
    <child link="frontright_camera"/>
  </joint>
  <link name="frontright_camera_optical"/>
  <joint name="frontright_camera_optical_joint" type="fixed">
    <origin rpy="-1.5707963 0 -1.5707963" xyz="0 0 0"/>
    <parent link="frontright_camera"/>
    <child link="frontright_camera_optical"/>
  </joint>
  <link name="left_camera"/>
  <joint name="left_camera_joint" type="fixed">
    <origin rpy="0 0.2 1.5707963" xyz="-0.125 0.12 0.035"/>
    <parent link="body"/>
    <child link="left_camera"/>
  </joint>
  <link name="left_camera_optical"/>
  <joint name="left_camera_optical_joint" type="fixed">
    <origin rpy="-1.5707963 0 -1.5707963" xyz="0 0 0"/>
    <parent link="left_camera"/>
    <child link="left_camera_optical"/>
  </joint>
  <link name="right_camera"/>
  <joint name="right_camera_joint" type="fixed">
    <origin rpy="0 0.2 -1.5707963" xyz="-0.125 -0.12 0.035"/>
    <parent link="body"/>
    <child link="right_camera"/>
  </joint>
  <link name="right_camera_optical"/>
