<robot name="spot">
  <link name="body">
    <visual>
      <geometry>
        <mesh filename="meshes/body.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/body_collision.stl"/>
      </geometry>
    </collision>
  </link>
  <link name="base_link"/>
  <joint name="base_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="body"/>
  </joint>
  <link name="front_rail"/>
  <joint name="front_rail_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.223 0 0.0805"/>
    <parent link="body"/>
    <child link="front_rail"/>
  </joint>
  <link name="real_front_rail"/>
